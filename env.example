# Copy to ".env" for local runs (optional — not needed on your laptop if Cloudflare allows direct access).
# On Render, set HTTPS_PROXY in the dashboard (same value as GridBot / HighOI).

# Cloud hosts (Render, Railway, AWS, etc.) often get Cloudflare 403 HTML from omni.variational.io.
# Use the same residential/ISP proxy as GridBot and HighOI:
# HTTPS_PROXY=https://user:pass@host:port

# Optional override (default https://omni.variational.io)
# VARI_BASE_URL=https://omni.variational.io
